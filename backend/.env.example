# Copy to backend/.env (or use the provided defaults below with Docker).

# --- SQLite: omit DATABASE_URL or comment it out ---
# Uses backend/banking.db automatically.

# --- PostgreSQL via Docker (project root) ---
#   docker compose up -d
#   cd backend && pip install -r requirements.txt && python init_db.py
DATABASE_URL=postgresql+psycopg2://banking:banking_dev@localhost:5432/banking
